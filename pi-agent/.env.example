# AEGIS Pi Agent — environment configuration
# Copy this to .env and fill in your values

# PAI orchestrator address (must be reachable from the Pi)
PAI_HOST=http://192.168.1.100:8000

# ──────────────────────────────────────────────────────────────
# Wake word — Vosk (primary, no signup, fully offline)
# 1. Install vosk: pip install vosk
# 2. Download model into models/vosk-model-small-en-us:
#    wget https://alphacephei.com/vosk/models/vosk-model-small-en-us-0.15.zip
#    unzip vosk-model-small-en-us-0.15.zip -d models/
#    mv models/vosk-model-small-en-us-0.15 models/vosk-model-small-en-us
WAKE_WORD=aegis

# openWakeWord fallback (used if Vosk model dir not present)
# Use a built-in name (hey_jarvis) or path to a custom .onnx model
WAKE_MODEL=hey_jarvis
WAKE_THRESHOLD=0.5

# Audio device (leave blank for system default)
# Run: python -c "import sounddevice; print(sounddevice.query_devices())" to list
AUDIO_DEVICE=

# Forward voice interactions to Telegram (1=yes, 0=no)
TELEGRAM_FORWARD=0
